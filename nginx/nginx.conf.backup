# Optimización de Nginx para alto tráfico concurrente
# Plan: Soporte >500 usuarios concurrentes con <500ms response time

# ============================================
# WORKER PROCESSES Y EVENTOS
# ============================================
worker_processes auto;
worker_rlimit_nofile 65535;

events {
    worker_connections 4096;
    use epoll;
    multi_accept on;
}

# ============================================
# CONFIGURACIÓN HTTP PRINCIPAL
# ============================================
http {
    # ============================================
    # ZONES PARA LIMITING
    # ============================================
    limit_req_zone $binary_remote_addr zone=api_limit:10m rate=10r/s;
    limit_conn_zone $binary_remote_addr zone=conn_limit:10m;

    # ============================================
    # PROXY CACHE
    # ============================================
    proxy_cache_path /var/cache/nginx levels=1:2 keys_zone=api_cache:10m max_size=100m inactive=60m use_temp_path=off;

    # ============================================
    # UPSTREAMS
    # ============================================
    upstream backend {
        least_conn;
        server backend:8000 max_fails=3 fail_timeout=30s;

        keepalive 32;
        keepalive_timeout 60s;
        keepalive_requests 100;
    }

    upstream landing {
        server landing:80;
    }

    # ============================================
    # BUFFERS DEL CLIENTE
    # ============================================
    client_body_buffer_size 128k;
    client_max_body_size 10m;
    client_header_buffer_size 1k;
    large_client_header_buffers 4 4k;

    # ============================================
    # BUFFERS DE PROXY
    # ============================================
    proxy_buffering on;
    proxy_buffer_size 4k;
    proxy_buffers 8 4k;
    proxy_busy_buffers_size 8k;

    # ============================================
    # TIMEOUTS DEL CLIENTE
    # ============================================
    client_body_timeout 12;
    client_header_timeout 12;
    keepalive_timeout 65;
    send_timeout 10;

    # ============================================
    # TIMEOUTS DE PROXY
    # ============================================
    proxy_connect_timeout 30;
    proxy_send_timeout 30;
    proxy_read_timeout 30;

    # ============================================
    # COMPRESIÓN GZIP
    # ============================================
    gzip on;
    gzip_vary on;
    gzip_proxied any;
    gzip_comp_level 6;
    gzip_min_length 256;
    gzip_disable "msie6";
    gzip_types text/plain text/css text/xml text/javascript
               application/json application/javascript application/xml+rss
               application/rss+xml font/truetype font/opentype
               application/vnd.ms-fontobject image/svg+xml;

    # ============================================
    # OPTIMIZACIÓN SSL/TLS
    # ============================================
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers 'ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384';
    ssl_prefer_server_ciphers off;

    # ============================================
    # LOGGING OPTIMIZADO
    # ============================================
    log_format main '$remote_addr - $remote_user [$time_local] "$request" '
                    '$status $body_bytes_sent "$http_referer" '
                    '"$http_user_agent" "$http_x_forwarded_for" '
                    'rt=$request_time uct="$upstream_connect_time" '
                    'uht="$upstream_header_time" urt="$upstream_response_time"';

    access_log /var/log/nginx/access.log main buffer=32k flush=5s;
    error_log /var/log/nginx/error.log warn;

    # ============================================
    # HEADERS DE PROXY POR DEFECTO
    # ============================================
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_http_version 1.1;
    proxy_set_header Connection "";

    # ============================================
    # HIDE SERVER VERSION
    # ============================================
    server_tokens off;

    # ============================================
    # SERVER BLOCK PARA dagi.co (landing) - HTTP
    # ============================================
    server {
        listen 80;
        server_name dagi.co;

        # Permitir validación de certbot ANTES del redirect
        location /.well-known/acme-challenge/ {
            root /var/www/certbot;
        }

        location / {
            return 301 https://$host$request_uri;
        }
    }

    # ============================================
    # SERVER BLOCK PARA nova.dagi.co y www - HTTP
    # ============================================
    server {
        listen 80;
        server_name nova.dagi.co www.nova.dagi.co;

        # Permitir validación de certbot ANTES del redirect
        location /.well-known/acme-challenge/ {
            root /var/www/certbot;
        }

        location / {
            return 301 https://$host$request_uri;
        }
    }

    # ============================================
    # SERVER BLOCK PARA otros subdominios - HTTP
    # ============================================
    server {
        listen 80;
        server_name *.nova.dagi.co;

        location / {
            return 301 https://$host$request_uri;
        }
    }

    # ============================================
    # SERVER BLOCK PARA dagi.co (landing) - HTTPS
    # ============================================
    server {
        listen 443 ssl;
        server_name dagi.co;

        ssl_certificate /etc/ssl/certs/fullchain.pem;
        ssl_certificate_key /etc/ssl/private/privkey.pem;

        location / {
            proxy_pass http://landing;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
        }
    }

    # ============================================
    # SERVER BLOCK PARA nova.dagi.co - HTTPS (OPTIMIZADO)
    # ============================================
    server {
        listen 443 ssl;
        server_name nova.dagi.co www.nova.dagi.co;

        ssl_certificate /etc/ssl/certs/fullchain.pem;
        ssl_certificate_key /etc/ssl/private/privkey.pem;

        # ============================================
        # MONITOREO DE NGINX STATUS
        # ============================================
        location /nginx_status {
            stub_status on;
            access_log off;
            allow 127.0.0.1;
            allow 172.16.0.0/12;
            allow 10.0.0.0/8;
            deny all;
        }

        # ============================================
        # FRONTEND (REACT)
        # ============================================
        location / {
            proxy_pass http://frontend:80;
            proxy_http_version 1.1;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection "upgrade";

            # Rate limiting para frontend
            limit_req zone=api_limit burst=20 nodelay;
            limit_conn conn_limit 10;
        }

        # ============================================
        # API BACKEND (DJANGO) CON CACHING
        # ============================================
        location /api/ {
            # CORS OPTIONS
            if ($request_method = OPTIONS) {
                add_header Access-Control-Allow-Origin $http_origin always;
                add_header Access-Control-Allow-Methods "GET, POST, OPTIONS, PUT, DELETE, PATCH" always;
                add_header Access-Control-Allow-Headers "Authorization,Content-Type,Accept" always;
                add_header Access-Control-Allow-Credentials true always;
                add_header Content-Length 0;
                add_header Content-Type text/plain;
                return 204;
            }

            # Proxy cache para endpoints read-heavy
            proxy_cache api_cache;
            proxy_cache_valid 200 302 1m;
            proxy_cache_valid 404 1m;
            proxy_cache_use_stale error timeout invalid_header updating;
            proxy_cache_background_update on;
            proxy_cache_lock on;

            # Rate limiting para API
            limit_req zone=api_limit burst=20 nodelay;
            limit_conn conn_limit 10;

            proxy_pass http://backend;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
        }

        # ============================================
        # ADMIN DJANGO
        # ============================================
        location /admin/ {
            proxy_pass http://backend;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
        }

        # ============================================
        # ARCHIVOS ESTÁTICOS CON CACHE LARGO
        # ============================================
        location ~* \.(jpg|jpeg|png|gif|ico|css|js|svg|woff|woff2|ttf|eot|webp)$ {
            proxy_pass http://frontend:80;
            expires 1y;
            add_header Cache-Control "public, immutable";
            access_log off;
        }

        # ============================================
        # STATIC FILES
        # ============================================
        location /static/ {
            alias /app/static/;
            expires 7d;
            add_header Cache-Control "public";

            # Cache de archivos estáticos
            location ~* \.(css|js|jpg|jpeg|png|gif|ico|svg|woff|woff2|ttf|eot)$ {
                expires 1y;
                add_header Cache-Control "public, immutable";
                access_log off;
            }
        }

        # ============================================
        # MEDIA FILES
        # ============================================
        location /media/ {
            alias /app/media/;
            expires 7d;
            add_header Cache-Control "public";
        }
    }

    # ============================================
    # SERVER BLOCK PARA otros subdominios - HTTPS
    # ============================================
    server {
        listen 443 ssl;
        server_name *.nova.dagi.co;

        ssl_certificate /etc/ssl/certs/fullchain.pem;
        ssl_certificate_key /etc/ssl/private/privkey.pem;

        location / {
            proxy_pass http://frontend:80;
            proxy_http_version 1.1;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection "upgrade";

            # Rate limiting
            limit_req zone=api_limit burst=20 nodelay;
            limit_conn conn_limit 10;
        }

        location /api/ {
            # CORS OPTIONS
            if ($request_method = OPTIONS) {
                add_header Access-Control-Allow-Origin $http_origin always;
                add_header Access-Control-Allow-Methods "GET, POST, OPTIONS, PUT, DELETE, PATCH" always;
                add_header Access-Control-Allow-Headers "Authorization,Content-Type,Accept" always;
                add_header Access-Control-Allow-Credentials true always;
                add_header Content-Length 0;
                add_header Content-Type text/plain;
                return 204;
            }

            # Proxy cache
            proxy_cache api_cache;
            proxy_cache_valid 200 302 1m;
            proxy_cache_valid 404 1m;
            proxy_cache_use_stale error timeout invalid_header updating;
            proxy_cache_background_update on;

            # Rate limiting
            limit_req zone=api_limit burst=20 nodelay;
            limit_conn conn_limit 10;

            proxy_pass http://backend;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
        }

        location /admin/ {
            proxy_pass http://backend;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
        }

        # Archivos estáticos con cache
        location ~* \.(jpg|jpeg|png|gif|ico|css|js|svg|woff|woff2|ttf|eot|webp)$ {
            proxy_pass http://frontend:80;
            expires 1y;
            add_header Cache-Control "public, immutable";
            access_log off;
        }

        location /static/ {
            alias /app/static/;
            expires 7d;
            add_header Cache-Control "public";
        }

        location /media/ {
            alias /app/media/;
            expires 7d;
            add_header Cache-Control "public";
        }
    }
}
